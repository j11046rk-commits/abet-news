---
// うなぎ太巻き 予約バトル（4者対戦・予約管理 兼 リアルタイム売上共有）
// 入力: 顧客名＋本数（誰の獲得かを記録）。売上(価格×本数)を最上部に表示。
// バックエンド: Supabase（REST + 2.5秒ポーリング）。接続情報は site.json の futomaki。
// イベント用ページのため noindex＋サイトマップ除外（astro.config.mjs）。
import site from '../../data/site.json';
const cfg = site.futomaki || {};
const SB_URL = (cfg.supabaseUrl || '').trim().replace(/\/$/, '');
const SB_KEY = (cfg.supabaseAnonKey || '').trim();
const GOAL = Number(cfg.goal || 200);
const PRICE = Number(cfg.price || 2500);
const EVENT_DATE = cfg.eventDate || '2026-07-26';
const DEADLINE_DATE = cfg.deadlineDate || '2026-07-24';
const PLAYERS = [
  { name: '古賀', color: '#3987e5', initial: '古' },
  { name: '山本', color: '#d55181', initial: '山' },
  { name: '岡', color: '#c98500', initial: '岡' },
  { name: 'しっぽり亭店販', color: '#199e70', initial: '店' },
];
const configured = !!(SB_URL && SB_KEY);
const nf0 = new Intl.NumberFormat('ja-JP');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#070b16" />
    <title>うなぎ太巻き 予約バトル｜しっぽり亭</title>
    <style is:global>
      :root {
        --bg: #070b16; --surface: #101828; --surface2: #0c1322; --line: rgba(255,255,255,.09);
        --txt: #eef2ff; --muted: #8b93ad; --gold: #ffcf5b;
        --g1: #6366f1; --g2: #22d3ee;
      }
      * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
      /* 連打対策: ダブルタップズーム無効＋テキスト選択防止 */
      button { touch-action: manipulation; -webkit-user-select: none; user-select: none; }
      body {
        margin: 0; color: var(--txt); padding-bottom: 132px;
        font-family: system-ui, -apple-system, "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
        line-height: 1.5; -webkit-font-smoothing: antialiased;
        background:
          radial-gradient(900px 500px at 10% -8%, rgba(99,102,241,.18), transparent 60%),
          radial-gradient(800px 500px at 100% 0%, rgba(34,211,238,.12), transparent 55%),
          radial-gradient(700px 600px at 80% 110%, rgba(255,207,91,.10), transparent 60%),
          var(--bg);
        min-height: 100vh; overflow-x: hidden;
      }
      .wrap { max-width: 680px; margin: 0 auto; padding: 20px 16px 40px; }
      .card { background: var(--surface); border: 1px solid var(--line); border-radius: 18px; padding: 16px 18px;
        backdrop-filter: blur(12px); }
      .mb { margin-bottom: 14px; }

      header.top { text-align: center; margin: 6px 0 16px; }
      header.top .emoji { font-size: 34px; line-height: 1; }
      header.top h1 { font-size: 22px; margin: 6px 0 2px; font-weight: 800; letter-spacing: .01em; }
      header.top .sub { font-size: 12px; color: var(--muted); }
      header.top .sub b { color: var(--gold); font-weight: 700; }
      .livedot { display:inline-block; width:7px; height:7px; border-radius:50%; background:#34d399;
        margin-right:5px; box-shadow:0 0 0 0 rgba(52,211,153,.7); animation:pulse 2s infinite; vertical-align:middle; }
      @keyframes pulse { 0%{box-shadow:0 0 0 0 rgba(52,211,153,.6);} 70%{box-shadow:0 0 0 7px rgba(52,211,153,0);} 100%{box-shadow:0 0 0 0 rgba(52,211,153,0);} }

      /* ===== 売上ヒーロー（最上部） ===== */
      .salescard { position: relative; overflow: hidden; text-align: center; padding: 20px 18px 18px;
        background: linear-gradient(160deg, rgba(99,102,241,.16), rgba(34,211,238,.07) 55%, rgba(255,207,91,.08)), var(--surface); }
      .salescard .lbl { font-size: 12px; color: var(--muted); letter-spacing:.08em; }
      .salescard .yen { font-size: 44px; font-weight: 800; letter-spacing:-.01em; margin: 2px 0 0; font-variant-numeric: tabular-nums;
        background: linear-gradient(180deg, #fff, #ffe9b3); -webkit-background-clip: text; background-clip: text; color: transparent; }
      .salescard .qty { font-size: 13px; color: var(--muted); margin-top: 2px; }
      .salescard .qty b { color: var(--txt); font-size: 15px; font-variant-numeric: tabular-nums; }
      .pbar { height: 12px; border-radius: 8px; background: var(--surface2); overflow: hidden; margin-top: 12px; }
      .pbar > span { display:block; height:100%; border-radius:8px; background: linear-gradient(90deg, var(--g1), var(--g2)); transition: width .6s cubic-bezier(.2,.8,.2,1); }
      .goaltxt { font-size:11.5px; color:var(--muted); margin-top:6px; }

      /* 各人売上ランキング */
      .row { display:grid; grid-template-columns: 24px 38px 1fr auto; align-items:center; gap:10px; padding:10px 6px; border-radius:12px; }
      .row.me { background: rgba(255,255,255,.05); }
      .rank { font-size:14px; font-weight:800; color:var(--muted); text-align:center; }
      .rank.first { color: var(--gold); }
      .avatar { width:38px; height:38px; border-radius:11px; display:grid; place-items:center; font-weight:800; font-size:15px; color:#fff; flex:none; }
      .pname { font-weight:700; font-size:14px; display:flex; align-items:center; gap:6px; }
      .pbar2 { height:12px; border-radius:8px; background: var(--surface2); overflow:hidden; margin-top:5px; }
      .pbar2 > span { display:block; height:100%; border-radius:8px; transition: width .7s cubic-bezier(.2,.8,.2,1); }
      .psales { text-align:right; }
      .psales .y { font-size:19px; font-weight:800; font-variant-numeric:tabular-nums; }
      .psales .q { font-size:11px; color:var(--muted); font-variant-numeric:tabular-nums; }
      .bump { animation: bump .5s ease; }
      @keyframes bump { 0%{transform:scale(1);} 35%{transform:scale(1.22);} 100%{transform:scale(1);} }

      .cd { display:flex; gap:6px; margin-top:6px; }
      .cd div { background: var(--surface2); border:1px solid var(--line); border-radius:9px; padding:6px 0; text-align:center; flex:1; }
      .cd .n { font-size:19px; font-weight:800; font-variant-numeric:tabular-nums; }
      .cd .u { font-size:10px; color:var(--muted); }
      .stat .lbl { font-size:11.5px; color:var(--muted); letter-spacing:.04em; }

      .sec { font-size: 12px; font-weight: 700; color:#cdd5ee; letter-spacing:.06em; margin: 22px 4px 12px; text-transform: uppercase;
        display:flex; align-items:center; gap:8px; }
      .sec::before { content:''; width:14px; height:2px; border-radius:2px; background: linear-gradient(90deg,var(--g1),var(--g2)); }
      .sec .cnt { color: var(--muted); font-weight: 600; }

      /* 予約一覧 */
      .resv { display:flex; align-items:center; gap:10px; padding:9px 4px; border-bottom:1px solid var(--line); font-size:13.5px; }
      .resv:last-child { border-bottom: 0; }
      .resv .dot { width:10px; height:10px; border-radius:50%; flex:none; }
      .resv .cust { font-weight:700; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
      .resv .by { font-size:11px; color:var(--muted); flex:none; }
      .resv .q { margin-left:auto; font-weight:800; font-variant-numeric:tabular-nums; flex:none; }
      .resv .yen2 { font-size:11px; color:var(--muted); flex:none; font-variant-numeric:tabular-nums; }
      .resv .del { flex:none; border:0; background:none; color:var(--muted); font-size:15px; cursor:pointer; padding:4px 6px; }
      .resv .del:active { color:#fb7185; }
      .more { text-align:center; padding-top:8px; }
      .more button { background:none; border:0; color:var(--g2); font-size:12.5px; font-weight:700; cursor:pointer; }

      svg text { fill: var(--muted); font-size: 10.5px; }

      /* 売上シェア（ドーナツ） */
      .share { display:flex; align-items:center; gap:18px; }
      .share svg { flex:none; }
      .slg { flex:1; min-width:0; }
      .slg .li { display:flex; align-items:center; gap:8px; font-size:13px; padding:5px 0; }
      .slg .dot2 { width:10px; height:10px; border-radius:3px; flex:none; }
      .slg .nm2 { font-weight:700; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
      .slg .yn { font-size:11px; color:var(--muted); font-variant-numeric:tabular-nums; flex:none; }
      .slg .pct { margin-left:auto; font-weight:800; font-variant-numeric:tabular-nums; flex:none; }

      .who { display:flex; flex-wrap:wrap; gap:8px; }
      .chip { flex:1 1 auto; min-width: 68px; text-align:center; padding:10px 8px; border-radius:12px; cursor:pointer;
        border:1px solid var(--line); background: var(--surface2); font-weight:700; font-size:13.5px; color:var(--txt); }
      .chip[aria-pressed="true"] { border-color: transparent; color:#fff; }

      /* 予約の編集（自分の分のみ） */
      .resv .act2 { display:flex; gap:2px; flex:none; }
      .resv .edit { flex:none; border:0; background:none; color:var(--muted); font-size:14px; cursor:pointer; padding:4px 6px; }
      .resv .edit:active { color:var(--g2); }
      .resv.editing { flex-wrap:wrap; }
      .ewrap { flex:1 1 100%; display:flex; flex-direction:column; gap:8px; padding:4px 0 2px; }
      .einp { width:100%; background:var(--surface2); border:1px solid var(--line); border-radius:10px; color:#fff; font-size:14.5px; padding:9px 11px; outline:none; }
      .einp:focus { border-color:var(--g2); }
      .erow { display:flex; align-items:center; gap:8px; }
      .stepper.mini button { width:36px; height:36px; font-size:16px; }
      .stepper.mini .qv { min-width:44px; font-size:15px; }
      .eyen { font-size:12px; color:var(--muted); flex:1; text-align:center; font-variant-numeric:tabular-nums; }
      .esave { border:0; border-radius:10px; padding:9px 16px; font-size:13.5px; font-weight:800; color:#fff; cursor:pointer; background:linear-gradient(135deg,var(--g1),var(--g2)); }
      .ecancel { border:1px solid var(--line); border-radius:10px; padding:9px 12px; font-size:13.5px; font-weight:700; color:var(--muted); background:var(--surface2); cursor:pointer; }

      /* ===== 下部固定: 予約入力 ===== */
      .dock { position: fixed; left:0; right:0; bottom:0; z-index:20; padding: 10px 12px calc(12px + env(safe-area-inset-bottom));
        background: rgba(10,14,24,.88); backdrop-filter: blur(14px); border-top:1px solid var(--line); }
      .dock .inner { max-width:680px; margin:0 auto; }
      .dock .prompt { text-align:center; color:var(--muted); font-size:13px; padding:6px 0; }
      .dock .l1 { display:flex; align-items:center; gap:8px; }
      .dock .miniava { width:34px; height:34px; border-radius:10px; display:grid; place-items:center; font-weight:800; color:#fff; flex:none; }
      .dock input[type="text"] { flex:1; min-width:0; background: var(--surface2); border:1px solid var(--line); border-radius:11px;
        color:#fff; font-size:15px; padding:11px 12px; outline:none; }
      .dock input:focus { border-color: var(--g2); }
      .dock .l2 { display:flex; align-items:center; gap:8px; margin-top:8px; }
      .stepper { display:flex; align-items:center; gap:0; border:1px solid var(--line); border-radius:11px; background:var(--surface2); overflow:hidden; }
      .stepper button { width:44px; height:44px; border:0; background:none; color:var(--txt); font-size:19px; font-weight:800; cursor:pointer; }
      .stepper button:active { background: rgba(255,255,255,.06); }
      .stepper .qv { min-width:52px; text-align:center; font-size:17px; font-weight:800; font-variant-numeric:tabular-nums; }
      .stepper .qv small { font-size:11px; color:var(--muted); font-weight:700; }
      .dock .amount { font-size:12px; color:var(--muted); font-variant-numeric:tabular-nums; flex:1; text-align:center; }
      .btnadd { border:0; border-radius:12px; padding: 12px 20px; font-size:15px; font-weight:800; color:#fff; cursor:pointer;
        background: linear-gradient(135deg, var(--g1), var(--g2)); box-shadow:0 6px 16px rgba(99,102,241,.4); }
      .btnadd:active { transform: translateY(1px) scale(.98); }
      .btnadd:disabled { opacity:.5; }

      #toasts { position: fixed; top: 12px; left:0; right:0; z-index:30; display:flex; flex-direction:column; align-items:center; gap:6px; pointer-events:none; }
      .toast { background: rgba(16,24,40,.95); border:1px solid var(--line); border-radius:999px; padding:7px 14px; font-size:13px; font-weight:700;
        box-shadow:0 8px 24px rgba(0,0,0,.4); animation: tin .3s ease, tout .3s ease 2.1s forwards; }
      @keyframes tin { from{opacity:0; transform:translateY(-8px);} to{opacity:1;} }
      @keyframes tout { to{opacity:0; transform:translateY(-8px);} }
      .conf { position: fixed; z-index: 40; top: -12px; width: 9px; height: 14px; border-radius: 2px; pointer-events:none; }
      .note { margin-top: 22px; font-size: 11px; color: var(--muted); border-top:1px solid var(--line); padding-top: 12px; text-align:center; }
      .empty { color:var(--muted); font-size:13px; padding:6px 2px; text-align:center; }
      .setup { text-align:center; padding: 30px 18px; }
      .setup h2 { font-size:16px; margin:0 0 8px; }
      .setup p { font-size:13px; color:var(--muted); }
      .setup code { background: var(--surface2); padding:2px 6px; border-radius:6px; }
    </style>
  </head>
  <body>
    <div id="toasts"></div>
    <div class="wrap">
      <header class="top">
        <div class="emoji">🍣🔥</div>
        <h1>うなぎ太巻き 予約バトル</h1>
        <div class="sub"><span class="livedot"></span>土用の丑の日・完全予約制 <b>7/24(金)締切</b> ／ 受け取り <b>7/26(日) 14:00〜17:00</b> ／ 1本 <b>¥{nf0.format(PRICE)}</b></div>
      </header>

      {!configured ? (
        <div class="card setup">
          <h2>⚙️ セットアップ待ち</h2>
          <p>Supabaseの接続情報が未設定です。<code>site.json</code> の <code>futomaki.supabaseUrl</code> と <code>supabaseAnonKey</code> を設定すると起動します。</p>
        </div>
      ) : (
        <>
          <!-- ① 売上（最上部） -->
          <div class="card salescard mb">
            <div class="lbl">全体の合計売上</div>
            <div class="yen">¥<span id="totalYen">0</span></div>
            <div class="qty">合計 <b id="totalQty">0</b> 本 ／ <span id="custCnt">0</span> 件の予約</div>
            <div class="pbar"><span id="pfill" style="width:0%"></span></div>
            <div class="goaltxt" id="goaltxt">目標 {GOAL} 本（¥{nf0.format(GOAL * PRICE)}）</div>
          </div>

          <!-- ② 各人の売上ランキング -->
          <div class="card mb" id="board"><div class="empty">読み込み中…</div></div>

          <!-- ②' 売上シェア（円グラフ） -->
          <div class="sec">売上シェア</div>
          <div class="card mb"><div class="share" id="share"><div class="empty">読み込み中…</div></div></div>

          <!-- ③ カウントダウン -->
          <div class="card stat mb">
            <div class="lbl" id="cdlbl">予約締切（7/24 金）まで</div>
            <div class="cd" id="cd">
              <div><div class="n" data-cd="d">--</div><div class="u">日</div></div>
              <div><div class="n" data-cd="h">--</div><div class="u">時</div></div>
              <div><div class="n" data-cd="m">--</div><div class="u">分</div></div>
              <div><div class="n" data-cd="s">--</div><div class="u">秒</div></div>
            </div>
          </div>

          <div class="sec">予約一覧 <span class="cnt" id="resvCnt"></span></div>
          <div class="card" id="resvList"><div class="empty">まだ予約がありません</div></div>

          <div class="sec">売上の推移</div>
          <div class="card"><svg id="chart" viewBox="0 0 640 220" width="100%" preserveAspectRatio="xMidYMid meet" role="img" aria-label="売上の推移"></svg></div>

          <div class="sec">自分はどれ？</div>
          <div class="card"><div class="who" id="who"></div></div>

          <p class="note">全員の画面にリアルタイム同期（約2.5秒）。予約の修正は ✎、取り消しは ✕ から（自分の分のみ）。データ: Supabase。</p>
        </>
      )}
    </div>

    {configured && (
      <div class="dock" id="dock" style="display:none"><div class="inner" id="dockInner"></div></div>
    )}

    {configured && (
      <script define:vars={{ SB_URL, SB_KEY, GOAL, PRICE, EVENT_DATE, DEADLINE_DATE, PLAYERS }}>
        const H = { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY };
        const REST = SB_URL + '/rest/v1/';
        const byName = Object.fromEntries(PLAYERS.map(p => [p.name, p]));
        let rows = [];            // {id, player, customer, qty, created_at}
        let prevTotals = null;    // 他者加算トースト用
        let me = null;
        let qtyInput = 1;
        let showAll = false;
        let editingId = null;   // 編集中の予約id（null=非編集）
        let editQty = 1;

        try { me = localStorage.getItem('futomaki_me'); } catch(e){}
        if (me && !byName[me]) me = null;

        const $ = s => document.querySelector(s);
        // スマホ連打対応タップ: touchstartで既定動作を止めて即実行 →
        // 入力欄のフォーカスが外れずキーボードが閉じない＆反応も速い。
        // touchstartをキャンセルするとエミュレートclickは発火しないが、二重発火ガードも念のため。
        function bindTap(elm, fn){
          let viaTouch = false;
          elm.addEventListener('touchstart', e => { e.preventDefault(); viaTouch = true; fn(); }, { passive: false });
          elm.addEventListener('click', () => { if (viaTouch) { viaTouch = false; return; } fn(); });
        }
        const fmt = n => new Intl.NumberFormat('ja-JP').format(n);
        const esc = s => String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

        // ---- API ----
        async function fetchAll(){
          const r = await fetch(REST + 'futomaki_reservations?select=id,player,customer,qty,created_at&order=created_at.asc', { headers: H });
          if (!r.ok) throw new Error(await r.text());
          return r.json();
        }
        async function addResv(customer, qty){
          const r = await fetch(REST + 'futomaki_reservations', {
            method:'POST', headers:{...H,'Content-Type':'application/json','Prefer':'return=representation'},
            body: JSON.stringify({ player: me, customer, qty })
          });
          if (!r.ok) throw new Error(await r.text());
          return (await r.json())[0];
        }
        async function delResv(id){
          const r = await fetch(REST + 'futomaki_reservations?id=eq.' + id, { method:'DELETE', headers:{...H,'Prefer':'return=minimal'} });
          if (!r.ok) throw new Error(await r.text());
        }
        async function updResv(id, customer, qty){
          const r = await fetch(REST + 'futomaki_reservations?id=eq.' + id, {
            method:'PATCH', headers:{...H,'Content-Type':'application/json','Prefer':'return=representation'},
            body: JSON.stringify({ customer, qty })
          });
          if (!r.ok) throw new Error(await r.text());
          return (await r.json())[0];
        }

        // ---- 集計 ----
        function totals(){
          const t = Object.fromEntries(PLAYERS.map(p => [p.name, 0]));
          rows.forEach(r => { if (t[r.player] != null) t[r.player] += r.qty; });
          return t;
        }

        // ---- 演出 ----
        let actx = null;
        function beep(freq){
          try {
            actx = actx || new (window.AudioContext||window.webkitAudioContext)();
            const o = actx.createOscillator(), g = actx.createGain();
            o.type='triangle'; o.frequency.value=freq; o.connect(g); g.connect(actx.destination);
            g.gain.setValueAtTime(.0001, actx.currentTime);
            g.gain.exponentialRampToValueAtTime(.25, actx.currentTime+.01);
            g.gain.exponentialRampToValueAtTime(.0001, actx.currentTime+.25);
            o.start(); o.stop(actx.currentTime+.26);
          } catch(e){}
        }
        function confetti(color){
          const cols = [color, '#ffcf5b', '#22d3ee', '#fff'];
          for (let i=0;i<26;i++){
            const d = document.createElement('div');
            d.className='conf'; d.style.background = cols[i%cols.length];
            d.style.left = (10 + Math.random()*80) + 'vw';
            d.style.marginLeft = ((Math.random()*2-1)*30) + 'px';
            d.style.transform = 'rotate(' + (Math.random()*360) + 'deg)';
            document.body.appendChild(d);
            d.animate([{top:'-12px',opacity:1},{top:'100vh',opacity:1,offset:.9},{top:'100vh',opacity:0}],
              { duration: 900+Math.random()*700, easing:'cubic-bezier(.3,.7,.4,1)' });
            d.getAnimations().forEach(a => a.onfinish = () => d.remove());
          }
        }
        function toast(msg){
          const t = document.createElement('div'); t.className='toast'; t.innerHTML = msg;
          $('#toasts').appendChild(t); setTimeout(()=>t.remove(), 2500);
        }

        // ---- レンダリング ----
        function renderHero(){
          const t = totals();
          const qty = PLAYERS.reduce((s,p)=>s+t[p.name],0);
          $('#totalYen').textContent = fmt(qty * PRICE);
          $('#totalQty').textContent = fmt(qty);
          $('#custCnt').textContent = fmt(rows.length);
          const pct = Math.min(100, GOAL ? qty/GOAL*100 : 0);
          $('#pfill').style.width = pct + '%';
          const remain = Math.max(0, GOAL - qty);
          $('#goaltxt').textContent = remain > 0
            ? ('目標 ' + fmt(GOAL) + ' 本（¥' + fmt(GOAL*PRICE) + '）／ あと ' + fmt(remain) + ' 本！')
            : ('🎉 目標達成！ ' + fmt(qty) + ' 本 ¥' + fmt(qty*PRICE));
        }
        function renderBoard(bumpName){
          const t = totals();
          const sorted = [...PLAYERS].sort((a,b)=>t[b.name]-t[a.name]);
          const max = Math.max(1, ...PLAYERS.map(p=>t[p.name]));
          const board = $('#board'); board.innerHTML = '';
          sorted.forEach((p,i)=>{
            const q = t[p.name], row = document.createElement('div');
            row.className = 'row' + (p.name===me?' me':'');
            const w = Math.max(q>0?6:0, q/max*100);
            row.innerHTML =
              '<div class="rank '+(i===0&&q>0?'first':'')+'">'+(i+1)+'</div>' +
              '<div class="avatar" style="background:'+p.color+'">'+p.initial+'</div>' +
              '<div><div class="pname">'+p.name+(i===0&&q>0?' <span>👑</span>':'')+'</div>' +
                '<div class="pbar2"><span style="width:'+w+'%;background:'+p.color+'"></span></div></div>' +
              '<div class="psales'+(p.name===bumpName?' bump':'')+'"><div class="y" style="color:'+p.color+'">¥'+fmt(q*PRICE)+'</div>' +
                '<div class="q">'+fmt(q)+' 本</div></div>';
            board.appendChild(row);
          });
        }
        function renderShare(){
          const t = totals();
          const qty = PLAYERS.reduce((s,p)=>s+t[p.name],0);
          const el = $('#share');
          const R2 = 44, C2 = 2*Math.PI*R2, SW = 18;
          let svg = '<svg width="132" height="132" viewBox="0 0 110 110" role="img" aria-label="売上シェア">';
          svg += '<circle cx="55" cy="55" r="'+R2+'" fill="none" stroke="rgba(255,255,255,.07)" stroke-width="'+SW+'"/>';
          if (qty > 0) {
            let off = 0;
            PLAYERS.forEach(p => {
              const frac = t[p.name]/qty;
              if (frac <= 0) return;
              const len = frac*C2;
              const seg = Math.max(.5, len-2); // セグメント間に2pxの隙間
              svg += '<circle cx="55" cy="55" r="'+R2+'" fill="none" stroke="'+p.color+'" stroke-width="'+SW+'" stroke-dasharray="'+seg+' '+(C2-seg)+'" stroke-dashoffset="'+(-off)+'" transform="rotate(-90 55 55)"/>';
              off += len;
            });
          }
          const yen = qty*PRICE;
          const yenLabel = yen >= 10000 ? (Math.round(yen/1000)/10)+'万' : fmt(yen);
          svg += '<text x="55" y="51" text-anchor="middle" style="font-size:10px">合計</text>';
          svg += '<text x="55" y="66" text-anchor="middle" style="font-size:13px;font-weight:800" fill="#eef2ff">¥'+yenLabel+'</text></svg>';
          let lg = '<div class="slg">';
          [...PLAYERS].sort((a,b)=>t[b.name]-t[a.name]).forEach(p => {
            const pc = qty > 0 ? Math.round(t[p.name]/qty*100) : 0;
            lg += '<div class="li"><span class="dot2" style="background:'+p.color+'"></span><span class="nm2">'+p.name+'</span><span class="yn">¥'+fmt(t[p.name]*PRICE)+'</span><span class="pct">'+pc+'%</span></div>';
          });
          lg += '</div>';
          el.innerHTML = svg + lg;
        }
        function renderList(){
          const list = $('#resvList');
          $('#resvCnt').textContent = rows.length ? '（' + rows.length + '件）' : '';
          if (!rows.length) { list.innerHTML = '<div class="empty">まだ予約がありません</div>'; return; }
          const desc = [...rows].reverse();
          const shown = showAll ? desc : desc.slice(0, 8);
          list.innerHTML = '';
          shown.forEach(r => {
            const p = byName[r.player] || { color:'#888' };
            const el = document.createElement('div');
            // 編集モード（自分の行のみ）
            if (r.player===me && editingId===r.id) {
              el.className = 'resv editing';
              el.innerHTML =
                '<span class="dot" style="background:'+p.color+'"></span>' +
                '<div class="ewrap">' +
                  '<input class="einp" id="editName" maxlength="30" autocomplete="off" />' +
                  '<div class="erow">' +
                    '<div class="stepper mini"><button id="eminus" type="button">−</button><div class="qv"><span id="eqv">'+editQty+'</span> <small>本</small></div><button id="eplus" type="button">＋</button></div>' +
                    '<span class="eyen" id="eyen">¥'+fmt(editQty*PRICE)+'</span>' +
                    '<button class="esave" id="esave" type="button">保存</button>' +
                    '<button class="ecancel" id="ecancel" type="button">やめる</button>' +
                  '</div>' +
                '</div>';
              list.appendChild(el);
              const ni = el.querySelector('#editName');
              ni.value = r.customer;
              const setEQ = q => { editQty = Math.min(99, Math.max(1, q)); el.querySelector('#eqv').textContent = editQty; el.querySelector('#eyen').textContent = '¥'+fmt(editQty*PRICE); };
              bindTap(el.querySelector('#eminus'), () => setEQ(editQty-1));
              bindTap(el.querySelector('#eplus'), () => setEQ(editQty+1));
              el.querySelector('#ecancel').onclick = () => { editingId = null; renderList(); };
              el.querySelector('#esave').onclick = async () => {
                const name = ni.value.trim();
                if (!name) { toast('お名前を入れてください'); ni.focus(); return; }
                try {
                  const rec = await updResv(r.id, name, editQty);
                  rows = rows.map(x => x.id===r.id ? rec : x);
                  editingId = null;
                  prevTotals = totals();
                  renderAll();
                  toast('✏️ 修正しました');
                } catch(e) { toast('⚠️ 修正に失敗。もう一度お試しを'); }
              };
              return;
            }
            el.className = 'resv';
            el.innerHTML =
              '<span class="dot" style="background:'+p.color+'"></span>' +
              '<span class="cust">'+esc(r.customer)+'</span>' +
              '<span class="by">'+esc(r.player)+'</span>' +
              '<span class="q">'+fmt(r.qty)+'本</span>' +
              '<span class="yen2">¥'+fmt(r.qty*PRICE)+'</span>' +
              (r.player===me ? '<span class="act2"><button class="edit" title="修正" data-eid="'+r.id+'">✎</button><button class="del" title="取り消し" data-id="'+r.id+'">✕</button></span>' : '');
            list.appendChild(el);
          });
          if (desc.length > 8) {
            const m = document.createElement('div'); m.className='more';
            m.innerHTML = '<button>' + (showAll ? '閉じる' : 'すべて見る（' + desc.length + '件）') + '</button>';
            m.querySelector('button').onclick = () => { showAll = !showAll; renderList(); };
            list.appendChild(m);
          }
          list.querySelectorAll('.edit').forEach(b => b.onclick = () => {
            const row = rows.find(x => x.id === +b.dataset.eid);
            if (!row) return;
            editingId = row.id; editQty = row.qty;
            renderList();
          });
          list.querySelectorAll('.del').forEach(b => b.onclick = async () => {
            const id = +b.dataset.id;
            const row = rows.find(x=>x.id===id);
            if (!row) return;
            if (!confirm('「'+row.customer+' '+row.qty+'本」を取り消しますか？')) return;
            rows = rows.filter(x=>x.id!==id);
            prevTotals = totals();
            renderAll();
            try { await delResv(id); toast('取り消しました'); } catch(e){ toast('⚠️ 取り消しに失敗'); sync(true); }
          });
        }
        function renderChart(){
          const svg = $('#chart'); const W=640,Hh=220, pad={l:44,r:54,t:14,b:22};
          const iw=W-pad.l-pad.r, ih=Hh-pad.t-pad.b;
          if (rows.length < 2) {
            svg.innerHTML = '<text x="'+(W/2)+'" y="'+(Hh/2)+'" text-anchor="middle">予約が増えると推移が表示されます</text>';
            return;
          }
          // 累積売上（プレイヤー別・階段状）
          const cum = {}; PLAYERS.forEach(p=>cum[p.name]=0);
          const series = {}; PLAYERS.forEach(p=>series[p.name]=[]);
          const t0 = +new Date(rows[0].created_at), t1 = +new Date(rows[rows.length-1].created_at);
          rows.forEach(r => {
            if (cum[r.player]==null) return;
            cum[r.player] += r.qty * PRICE;
            series[r.player].push({ t:+new Date(r.created_at), v:cum[r.player] });
          });
          const maxV = Math.max(1, ...PLAYERS.map(p=>cum[p.name]));
          const tx = t => pad.l + (t1>t0 ? (t-t0)/(t1-t0)*iw : iw/2);
          const ty = v => pad.t + ih - (v/maxV)*ih;
          let out = '';
          [0, Math.ceil(maxV/2), maxV].forEach(v => {
            out += '<line x1="'+pad.l+'" x2="'+(W-pad.r)+'" y1="'+ty(v)+'" y2="'+ty(v)+'" stroke="rgba(255,255,255,.06)"/>' +
                   '<text x="'+(pad.l-6)+'" y="'+(ty(v)+3)+'" text-anchor="end">'+(v>=10000?(Math.round(v/1000)/10)+'万':fmt(v))+'</text>';
          });
          PLAYERS.forEach(p => {
            const pts = series[p.name]; if (!pts.length) return;
            let d = 'M ' + tx(t0) + ',' + ty(0);
            let last = 0;
            pts.forEach(pt => { d += ' L ' + tx(pt.t) + ',' + ty(last) + ' L ' + tx(pt.t) + ',' + ty(pt.v); last = pt.v; });
            d += ' L ' + tx(t1) + ',' + ty(last);
            out += '<path d="'+d+'" fill="none" stroke="'+p.color+'" stroke-width="2.5" stroke-linejoin="round"/>';
            out += '<circle cx="'+tx(pts[pts.length-1].t)+'" cy="'+ty(last)+'" r="3.5" fill="'+p.color+'"/>';
            out += '<text x="'+(W-pad.r+5)+'" y="'+(ty(last)+3)+'" fill="'+p.color+'" style="font-weight:700">'+ p.initial +'</text>';
          });
          svg.innerHTML = out;
        }
        function renderWho(){
          const who = $('#who'); who.innerHTML='';
          PLAYERS.forEach(p => {
            const b = document.createElement('button');
            b.className='chip'; b.setAttribute('aria-pressed', String(p.name===me));
            if (p.name===me) b.style.background = p.color;
            b.textContent = p.name;
            b.onclick = () => { me = p.name; try{localStorage.setItem('futomaki_me',me);}catch(e){} renderWho(); renderBoard(); renderList(); renderDock(); };
            who.appendChild(b);
          });
        }
        function renderDock(){
          const dock = $('#dock'), inner = $('#dockInner');
          dock.style.display = 'block';
          if (!me) { inner.innerHTML = '<div class="prompt">▲ 「自分はどれ？」で自分を選ぶと予約を入力できます</div>'; return; }
          const p = byName[me];
          inner.innerHTML =
            '<div class="l1">' +
              '<div class="miniava" style="background:'+p.color+'">'+p.initial+'</div>' +
              '<input type="text" id="custName" placeholder="お客様のお名前（例: 田中様）" maxlength="30" autocomplete="off" />' +
            '</div>' +
            '<div class="l2">' +
              '<div class="stepper">' +
                '<button id="qminus" type="button">−</button>' +
                '<div class="qv"><span id="qv">'+qtyInput+'</span> <small>本</small></div>' +
                '<button id="qplus" type="button">＋</button>' +
              '</div>' +
              '<div class="amount" id="amount">¥'+fmt(qtyInput*PRICE)+'</div>' +
              '<button class="btnadd" id="addBtn" type="button">予約を登録</button>' +
            '</div>';
          const qv = $('#qv'), amount = $('#amount');
          const setQ = q => { qtyInput = Math.min(99, Math.max(1, q)); qv.textContent = qtyInput; amount.textContent = '¥' + fmt(qtyInput*PRICE); };
          // touchstartで処理してキーボードを閉じさせない（連打対応）
          bindTap($('#qminus'), () => setQ(qtyInput-1));
          bindTap($('#qplus'), () => setQ(qtyInput+1));
          $('#addBtn').onclick = submit;
          // Enterで登録（ただし日本語IMEの変換確定Enterでは発火させない）
          $('#custName').addEventListener('keydown', e => {
            if (e.key==='Enter' && !e.isComposing && e.keyCode !== 229) { e.preventDefault(); submit(); }
          });
        }
        function renderAll(bumpName){ renderHero(); renderBoard(bumpName); renderShare(); renderList(); renderChart(); }

        async function submit(){
          const inp = $('#custName');
          const name = (inp.value||'').trim();
          if (!name) { toast('お客様のお名前を入れてください'); inp.focus(); return; }
          const btn = $('#addBtn'); btn.disabled = true;
          const q = qtyInput;
          try {
            const rec = await addResv(name, q);
            rows.push(rec);
            prevTotals = totals();
            renderAll(me);
            confetti(byName[me].color);
            beep(q>=5?880:660);
            toast('🎉 '+esc(name)+' '+q+'本（¥'+fmt(q*PRICE)+'）を登録！');
            inp.value=''; qtyInput=1;
            const qv=$('#qv'), am=$('#amount');
            if (qv) qv.textContent='1';
            if (am) am.textContent='¥'+fmt(PRICE);
          } catch(e) { toast('⚠️ 登録に失敗。通信を確認してもう一度'); }
          btn.disabled = false;
        }

        // ---- 同期 ----
        let firstLoad = true;
        async function sync(){
          try {
            const next = await fetchAll();
            const before = prevTotals;
            rows = next;
            const t = totals();
            if (!firstLoad && before) {
              PLAYERS.forEach(p => {
                const d = t[p.name]-(before[p.name]||0);
                if (d>0 && p.name!==me) toast('<span style="color:'+p.color+'">'+p.name+'</span> が +'+d+'本（¥'+fmt(d*PRICE)+'）🔥');
              });
            }
            prevTotals = t;
            if (editingId === null) renderAll();
            else { renderHero(); renderBoard(); renderShare(); renderChart(); } // 編集中は一覧を再描画しない（入力内容を守る）
            firstLoad = false;
          } catch(e) {}
        }

        // ---- カウントダウン（予約締切 → 受け取り開始） ----
        const deadline = new Date(DEADLINE_DATE + 'T23:59:59+09:00').getTime();
        const eventStart = new Date(EVENT_DATE + 'T14:00:00+09:00').getTime();
        function tick(){
          const now = Date.now();
          let target = null, lbl;
          if (now < deadline) { target = deadline; lbl = '予約締切（7/24 金）まで'; }
          else if (now < eventStart) { target = eventStart; lbl = '受け取り開始（7/26 日 14:00）まで'; }
          else { lbl = '🔥 受け取り実施中・ラストスパート！'; }
          $('#cdlbl').textContent = lbl;
          const set = (k,v)=>{ const el=document.querySelector('[data-cd="'+k+'"]'); if(el) el.textContent = String(v).padStart(2,'0'); };
          if (!target) { set('d','0'); set('h','00'); set('m','00'); set('s','00'); return; }
          const s = Math.max(0, Math.floor((target-now)/1000));
          set('d', Math.floor(s/86400)); set('h', Math.floor(s%86400/3600)); set('m', Math.floor(s%3600/60)); set('s', s%60);
        }

        // ---- 起動 ----
        renderWho(); renderDock(); renderAll();
        tick(); setInterval(tick, 1000);
        sync();
        setInterval(sync, 2500);
        document.addEventListener('visibilitychange', () => { if (!document.hidden) sync(); });
      </script>
    )}
  </body>
</html>
