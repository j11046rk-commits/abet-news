---
import site from '../../data/site.json';
import { withBase } from '../lib/text.js';
import Icon from './Icon.astro';
const s = site.店舗情報;
const tel = s.電話番号.replace(/-/g, '');
const hasPhoto = s.ヒーロー画像 && s.ヒーロー画像.trim() !== '';
const badges = s.ヒーローバッジ || [];
---
<section class={`hero ${hasPhoto ? 'hero--photo' : ''}`} aria-label="しっぽり亭 トップ">
  {hasPhoto
    ? <div class="hero__bg hero__bg--photo" style={`background-image:url(${withBase(s.ヒーロー画像)})`} aria-hidden="true"></div>
    : <div class="hero__bg" aria-hidden="true"></div>}
  <div class="hero__inner">
    <p class="hero__roman">Izakaya {s.店名ローマ字} ・ Niihama</p>
    <h1 class="hero__title">{s.店名}</h1>
    <p class="hero__catch">{s.キャッチコピー}</p>
    <p class="hero__sub">{s.サブキャッチ}</p>
    {badges.length > 0 && (
      <ul class="hero__badges" aria-label="お店のポイント">
        {badges.map((b) => <li class="hero__badge">{b}</li>)}
      </ul>
    )}
    <div class="hero__cta">
      <a class="btn btn--primary btn--lg" href={`tel:${tel}`}>
        <Icon name="phone" size={20} />
        <span>お電話でご予約</span>
        <span class="btn__phone-num">{s.電話番号表示用}</span>
      </a>
      <a class="btn btn--ghost btn--lg" href="#banquet">宴会・コースを見る</a>
    </div>
  </div>
  <a class="hero__scroll" href="#concept" aria-label="下へスクロール"><span></span></a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem var(--pad);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 90% at 50% 0%, rgba(210,162,92,0.14), transparent 55%),
      radial-gradient(90% 70% at 80% 105%, rgba(196,122,61,0.16), transparent 60%),
      linear-gradient(180deg, #111726 0%, #161d30 55%, #111726 100%);
  }
  .hero__bg::after {
    /* 木目を思わせる縦のうっすらした筋でテクスチャ感 */
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg, rgba(210,162,92,0.05) 0 1px, transparent 1px 34px),
      repeating-linear-gradient(90deg, rgba(196,122,61,0.04) 0 1px, transparent 1px 9px);
    mask-image: radial-gradient(closest-side, #000 0%, transparent 92%);
    opacity: 0.55;
  }
  .hero__inner { position: relative; max-width: 40rem; }
  .hero__roman {
    font-size: 0.72rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 1.4rem;
  }
  .hero__title {
    font-size: clamp(3rem, 16vw, 5.6rem);
    margin: 0;
    color: var(--text);
    text-shadow: 0 2px 30px rgba(0,0,0,0.5);
    letter-spacing: 0.1em;
  }
  .hero__catch {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 5vw, 1.5rem);
    color: var(--gold-soft);
    margin: 1.2rem 0 0.4rem;
    letter-spacing: 0.1em;
  }
  .hero__sub { color: var(--text-dim); font-size: 0.95rem; margin: 0 0 1.4rem; }
  .hero__badges {
    list-style: none; margin: 0 0 2rem; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center;
  }
  .hero__badge {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.02em;
    color: var(--gold-soft);
    background: rgba(210,162,92,0.12);
    border: 1px solid rgba(210,162,92,0.4);
    border-radius: 999px;
    padding: 0.35em 0.9em;
  }
  .hero__cta { display: flex; flex-direction: column; gap: 0.8rem; align-items: stretch; }
  /* 写真ヒーロー用：暗い被せで文字を読みやすく */
  .hero__bg--photo {
    background-size: cover; background-position: center;
  }
  .hero--photo .hero__bg--photo::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(17,23,38,0.72), rgba(17,23,38,0.86));
  }
  .hero__scroll {
    position: absolute;
    bottom: 1.4rem; left: 50%;
    transform: translateX(-50%);
    width: 24px; height: 40px;
    border: 1px solid var(--line);
    border-radius: 12px;
  }
  .hero__scroll span {
    position: absolute; left: 50%; top: 8px;
    width: 3px; height: 8px; border-radius: 2px;
    background: var(--gold);
    transform: translateX(-50%);
    animation: scroll 1.6s ease-in-out infinite;
  }
  @keyframes scroll { 0%{opacity:0;transform:translate(-50%,0)} 40%{opacity:1} 100%{opacity:0;transform:translate(-50%,14px)} }
  @media (min-width: 560px) {
    .hero__cta { flex-direction: row; justify-content: center; }
  }
</style>
