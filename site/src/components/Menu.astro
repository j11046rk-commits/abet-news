---
import site from '../../data/site.json';
import { isTBC } from '../lib/text.js';
const m = site.看板メニュー;
---
<section class="section section--alt" id="menu" aria-labelledby="menu-title">
  <div class="container">
    <div class="section__head">
      <p class="section__kicker">Signature Menu</p>
      <h2 class="section__title" id="menu-title">{m.見出し}</h2>
      <p class="section__lead">{m.リード}</p>
    </div>
    <ul class="menu-grid">
      {m.品目.map((item) => (
        <li class="card menu-card">
          <div class="menu-card__media">
            <img src={item.画像} alt={item.alt} width="600" height="450" loading="lazy" decoding="async" />
          </div>
          <div class="menu-card__body">
            <h3 class="menu-card__name">{item.名前}</h3>
            <p class="menu-card__price">
              {isTBC(item.価格) ? <span class="tbc">価格 要確認</span> : <>¥{item.価格}</>}
            </p>
            <p class="menu-card__desc">{item.説明}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .menu-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .menu-card { display: flex; flex-direction: column; }
  .menu-card__media { aspect-ratio: 4 / 3; background: var(--bg-2); }
  .menu-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .menu-card__body { padding: 1rem 1rem 1.2rem; }
  .menu-card__name { margin: 0; font-size: 1.02rem; color: var(--text); }
  .menu-card__price { margin: 0.3rem 0 0.5rem; color: var(--gold-soft); font-family: var(--font-serif); font-size: 1.05rem; }
  .menu-card__desc { margin: 0; font-size: 0.85rem; color: var(--text-dim); line-height: 1.7; }
  @media (min-width: 760px) {
    .menu-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
